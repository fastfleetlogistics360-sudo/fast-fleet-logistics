NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
FASTFLEET_ADMIN_USERNAME=
FASTFLEET_ADMIN_PASSWORD=
FASTFLEET_ADMIN_SECRET=
FASTFLEET_ADMIN_USER_ID=
SQUAD_SECRET_KEY=sandbox_or_live_squad_secret_key
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com
SQUAD_CALLBACK_ORIGIN=http://localhost:3000
# Canonical HTTPS origin used only by server-side payment callback generation.
# In production set this to the one approved public host, with no trailing path.
PAYMENT_CALLBACK_ORIGIN=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Required for the real Google Maps layer. Without it, tracking falls back to the built-in CSS route preview.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=optional-google-maps-key
# Optional only if you add custom app-owned transactional email routes.
# Supabase Auth confirmation emails use Supabase Auth SMTP settings, where Resend is configured in the Supabase dashboard.
RESEND_API_KEY=optional-resend-api-key
# Required server-only secret for Vercel Cron. Use a strong random value of at least 32 characters.
CRON_SECRET=replace-with-a-random-secret-at-least-32-characters
# Never allow demo data in production unless you are intentionally running a staging preview.
NEXT_PUBLIC_ALLOW_DEMO_DATA=false
NEXT_PUBLIC_ALLOW_SUPABASE_FALLBACK=false

# OAuth is configured in Supabase Auth Providers, not in client code.
# Add app callback URLs to the Supabase Auth redirect allow list:
#   http://localhost:3000/auth/callback
#   https://your-domain.com/auth/callback
# In Google Cloud, add Supabase's provider callback URL as an authorized redirect URI:
#   https://your-project.supabase.co/auth/v1/callback
# Google provider: add GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET in Supabase.
# App Store note: if the native iOS app offers Google sign-in, Apple may require Sign in with Apple too.
# Do not expose OAuth client secrets as NEXT_PUBLIC_* variables.
